<hrule/>

<group>
    <stretch>true</stretch>
    <layout>hbox</layout>
    <halign>fill</halign>
    <valign>top</valign>
    <default-padding>6</default-padding>

<button>
    <pref-width>70</pref-width>
    <desc>Close</desc>
    <legend>Close</legend>
    <equal>true</equal>
    <repeatable type="bool">false</repeatable>
    <binding>
    <command>nasal</command>
    <script>
				if (getprop("/aaa/switches/EVAC_Cover")==0)
				setprop("/aaa/switches/EVACPnl.toggle", 0);
				setprop("/aaa/door-positions/l1/position-norm", 0);
				setprop("/aaa/door-positions/l2/position-norm", 0);
